{
  "realm": "helpdesk",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "employee",
        "description": "Regular employee who can submit and view their own tickets",
        "composite": false
      },
      {
        "name": "helpdesk-admin",
        "description": "Help desk administrator who can manage all tickets",
        "composite": false
      },
      {
        "name": "helpdesk-tester",
        "description": "Tester who can run Jenkins test jobs",
        "composite": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "helpdesk-frontend",
      "name": "HelpDesk Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:4200/*",
        "https://*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*##https://*"
      },
      "protocolMappers": [
        {
          "name": "helpdesk-backend-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "helpdesk-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "helpdesk-backend",
      "name": "HelpDesk Backend",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "backend-secret",
      "bearerOnly": true
    },
    {
      "clientId": "helpdesk-jenkins",
      "name": "HelpDesk Jenkins",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "secret": "jenkins-secret",
      "redirectUris": [
        "http://localhost:9090/securityRealm/finishLogin"
      ],
      "webOrigins": [
        "+"
      ],
      "protocolMappers": [
        {
          "name": "realm_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
